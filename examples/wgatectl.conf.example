# /etc/wgatectl.conf — settings for the wgatectl daemon
#
# Values here are overridden by matching environment variables on the
# service.  Every key is optional; defaults shown here match the compiled-in
# defaults.

# The LAN-facing interface to capture on.
WG_IFACE=lan

# The LAN subnet.  Only packets whose source or destination falls inside
# this subnet are considered.
WG_NETWORK=10.6.6.0/24

# Paths to the dnsmasq state files.
WG_DNSMASQ_CONF=/etc/dnsmasq.conf
WG_DNSMASQ_LEASES=/var/lib/misc/dnsmasq.leases

# Block-list persistence (a JSON array of IP or name strings).
WG_BLOCKS_JSON=/opt/wgatectl/blocks.json

# Schedule state (weekly base + pending one-shot overrides).  If missing,
# the hard-coded defaults apply (daily 07:00 supervised, 18:00 open;
# Sun/Mon/Wed/Thu 23:00 closed, Tue 23:30 closed, Sat/Sun 00:00 closed).
WG_SCHEDULE_JSON=/opt/wgatectl/schedule.json

# Supervised-mode targets: JSON array of domain suffixes (case-insensitive,
# label-boundary match).  The supervisor fully blocks any device whose
# traffic hits any of these for N consecutive minutes, for M minutes.
WG_SUPERVISED_JSON=/opt/wgatectl/supervised.json

# Supervisor trigger threshold and cool-down, in minutes.  Defaults:
# 5 minutes of consecutive matching traffic triggers a 60-minute block.
# Clamped to [1, 120] and [1, 1440] respectively.
WG_SUPERVISED_THRESHOLD_MIN=5
WG_SUPERVISED_COOLDOWN_MIN=60

# Minimum matched-domain traffic per minute (bytes) for the minute to
# count toward the consecutive-trigger counter.  Keepalives / idle
# heartbeats of a backgrounded app stay under this and don't accrue.
# Set to 0 to make any matching packet count.
WG_SUPERVISED_MIN_BYTES_PER_MIN=32768

# Per-device timed grants (JSON array of {key, until, reason}).  Populated
# and persisted by the /hosts/{key}/grant endpoint.
WG_GRANTS_JSON=/opt/wgatectl/grants.json

# Supervisor trigger list (JSON array of {key, until}).  Managed
# automatically; lives here so a restart doesn't release triggers early.
WG_TRIGGERS_JSON=/opt/wgatectl/triggers.json

# Where the per-minute JSONL events go.  Files are named events-YYYYMMDD.jsonl.
# The daemon creates this directory if it doesn't exist.
WG_JSONL_DIR=/opt/wgatectl
WG_JSONL_RETAIN=14

# Unix-socket control plane.  Lives alongside the JSONL files on persistent
# storage.  Mode is forced to 0660; if WG_SOCK_GROUP names an existing group
# the socket is chowned to root:<group>.
WG_SOCK=/opt/wgatectl/wgatectl.sock
WG_SOCK_GROUP=wgate

# Static-assignment zone: CIDR exempted from every FORWARD rule and
# proactively ARP-pinned on the LAN interface.  Devices listed as
# `dhcp-host=...` in dnsmasq.conf are pinned to their MAC; the remaining
# slots in the CIDR are pinned to a DUMMY MAC so they black-hole.
# Leave empty to disable both the exempt rule and the ARP binding.
WG_STATIC_CIDR=10.6.6.0/27

# External binaries (absolute paths so the daemon works under a strict
# systemd sandbox).
WG_IPTABLES_BIN=/sbin/iptables
WG_IPSET_BIN=/sbin/ipset
WG_IP_BIN=/sbin/ip

# Metrics flush cadence.  The main tick fires every second; this knob
# controls the JSONL flush period and iptables self-heal reconcile.
WG_FLUSH_SECONDS=60

# Development overrides — leave unset in production.
# WG_DEBUG=1
